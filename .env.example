# ---------------------------------------------------------------------------
# Provider routing
#
# ErrorNodeBench routes calls through litellm. By default the solver and
# consolidator hit the locally-running mgpt proxy (../mgpt) using its
# OpenAI-compatible /v1/chat/completions endpoint. Start mgpt with:
#     cd ../mgpt && just serve   # listens on :8080
# Then leave MGPT_BASE_URL as below.
# ---------------------------------------------------------------------------
MGPT_BASE_URL=http://localhost:8080/v1

# mgpt does not auth /v1/chat/completions, but litellm requires a non-empty
# key. Leave any placeholder.
OPENAI_API_KEY=mgpt-local

# Only needed if you route any role through Anthropic directly
# (e.g. --judge anthropic/claude-opus-4-7 to cross-check mgpt's verdicts).
ANTHROPIC_API_KEY=

# Only needed if you route any role through Gemini.
GEMINI_API_KEY=
